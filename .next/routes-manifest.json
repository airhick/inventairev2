{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin/data-tables",
      "regex": "^/admin/data\\-tables(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/data\\-tables(?:/)?$"
    },
    {
      "page": "/admin/default",
      "regex": "^/admin/default(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/default(?:/)?$"
    },
    {
      "page": "/admin/gallery",
      "regex": "^/admin/gallery(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/gallery(?:/)?$"
    },
    {
      "page": "/admin/inventory",
      "regex": "^/admin/inventory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/inventory(?:/)?$"
    },
    {
      "page": "/admin/location",
      "regex": "^/admin/location(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/location(?:/)?$"
    },
    {
      "page": "/admin/nft-marketplace",
      "regex": "^/admin/nft\\-marketplace(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/nft\\-marketplace(?:/)?$"
    },
    {
      "page": "/admin/profile",
      "regex": "^/admin/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/profile(?:/)?$"
    },
    {
      "page": "/admin/scanner",
      "regex": "^/admin/scanner(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/scanner(?:/)?$"
    },
    {
      "page": "/admin/voice-command",
      "regex": "^/admin/voice\\-command(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/voice\\-command(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/minimal",
      "regex": "^/minimal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/minimal(?:/)?$"
    },
    {
      "page": "/rtl/rtl-default",
      "regex": "^/rtl/rtl\\-default(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/rtl/rtl\\-default(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
